# Database (Neon Postgres)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Better Auth
BETTER_AUTH_SECRET=          # openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (Better Auth social provider)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# File storage (uploaded bank mutations — audit trail)
# Optional: set to use Vercel Blob in production. When unset, files are written
# to the local filesystem (UPLOAD_STORAGE_DIR, dev only — not persisted on Vercel).
BLOB_READ_WRITE_TOKEN=
# Local fallback directory for uploads when no Blob token is set (default .data/uploads).
UPLOAD_STORAGE_DIR=.data/uploads
